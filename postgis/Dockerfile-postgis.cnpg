COPY --from=builder /usr/lib/x86_64-linux-gnu/liblcms2.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libsz.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libminizip.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/liburiparser.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libfyut.so.* /lib/
