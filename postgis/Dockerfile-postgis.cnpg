FROM ghcr.io/cloudnative-pg/postgresql-trunk:18-cf-4913 AS builder

USER 0

RUN set -eux; \
	mkdir -p /opt/extension && \
	apt-get update && \
	apt-get install -y --no-install-recommends \
	clang-16 \
	llvm-16-dev \
	git \
	autoconf \
	automake \
	bison \
	build-essential \
	ca-certificates \
	cmake \
	docbook-xml \
	docbook5-xml \
	g++ \
	libboost-all-dev \
	libcunit1-dev \
	libcurl4-gnutls-dev \
	libgmp-dev \
	libjson-c-dev \
	libmpfr-dev \
	libpcre3-dev \
	libprotobuf-c-dev \
	libsqlite3-dev \
	libtiff-dev \
	libtool \
	libxml2-dev \
	libxml2-utils \
	make \
	pkg-config \
	protobuf-c-compiler \
	xsltproc \
	libsfcgal-dev \
	# runtime deps
	libproj25 \
	libproj-dev \
	libpq5 \
	libgdal-dev \
	libgdal32 \
	libgeos-dev \
	libgeos-c1v5 \
	libc6 \
	libsfcgal1 \
	&& \
	git clone -b master --single-branch https://github.com/postgis/postgis.git /tmp/postgis && \
	cd /tmp/postgis && \
	./autogen.sh && \
	./configure --with-pgconfig=/usr/lib/postgresql/18/bin/pg_config --prefix=/opt/extension/ --with-sfcgal && \
	make -j$(nproc) && \
	make install && \
	make install datadir=/opt/extension/share/ pkglibdir=/opt/extension/lib/

FROM scratch

COPY --from=builder /opt/extension/bin/* /bin/
COPY --from=builder /opt/extension/lib/* /lib/
COPY --from=builder /opt/extension/share/extension/* /share/
COPY --from=builder /opt/extension/share/contrib/* /contrib/

COPY --from=builder /usr/lib/x86_64-linux-gnu/libgdal.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libgeos.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libgeos_c.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libjson-c.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libpcre2*.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libproj.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libprotobuf-c.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libSFCGAL.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libstdc++.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libxml2.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libtiff.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libcurl.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libcurl-gnutls.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libwebp.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libLerc.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libjbig.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libjpeg.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libdeflate.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libnghttp2.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/librtmp.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libssh2.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libpsl.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libbrotlidec.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libbrotlicommon.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libodbc.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libodbcinst.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libgmpxx.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libblosc.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libboost_serialization.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libmpfr.so.* /lib/
