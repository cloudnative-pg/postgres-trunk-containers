COPY --from=builder /usr/lib/x86_64-linux-gnu/libplds4.so /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libnspr4.so /lib/

COPY --from=builder /usr/lib/libmfhdfalt.so.* /lib/
COPY --from=builder /usr/lib/libdfalt.so.* /lib/
COPY --from=builder /usr/lib/libogdi.so.* /lib/
COPY --from=builder /usr/lib/libarmadillo.so.* /lib/
