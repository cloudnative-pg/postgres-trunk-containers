COPY --from=builder /usr/lib/x86_64-linux-gnu/libgif.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libnetcdf.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libcfitsio.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libhdf5_serial.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libhdf5_serial_hl.so.* /lib/
COPY --from=builder /usr/lib/x86_64-linux-gnu/libopenjp2.so.* /lib/
